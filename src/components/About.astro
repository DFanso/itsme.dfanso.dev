---
const { class: className } = Astro.props;
---

<section class:list={[className]}>
    <div class="command-output">
        <div class="text-[#bb9af7] font-bold mb-2">Professional Summary</div>
        <div class="ml-4 border-l-2 border-[#565f89] pl-4 text-sm space-y-4">
            <p class="leading-relaxed text-[#c0caf5]">
                <span class="text-[#7aa2f7] font-bold">Senior Software Engineer</span> at <span class="text-[#7aa2f7]">Fun Extreme Technology</span> &amp;
                <span class="text-[#7aa2f7] font-bold">DevOps Engineer</span> at <span class="text-[#7aa2f7]">Empite</span>, holding a
                <span class="text-[#e0af68]">First-Class Honours</span> degree from the
                <span class="text-[#9ece6a]">University of Plymouth</span>. Experienced
                across DevOps pipelines, backend development, cloud infrastructure, and
                AI-driven automation.
            </p>
            
            <p class="leading-relaxed text-[#c0caf5]">
                <span class="text-[#bb9af7] font-bold">Co-Founder &amp; CTO</span> of
                <span class="text-[#7aa2f7]">CodeXeed</span> and <span class="text-[#7aa2f7]">KlexD</span>,
                building scalable cloud-native applications and intelligent systems for global clients.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                <div>
                    <div class="text-[#565f89] text-xs mb-1">FOCUS</div>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-[#1a1b26] border border-[#7aa2f7]/30 text-[#7aa2f7] px-2 py-1 rounded text-xs">DevOps Pipelines</span>
                        <span class="bg-[#1a1b26] border border-[#9ece6a]/30 text-[#9ece6a] px-2 py-1 rounded text-xs">Cloud Infrastructure</span>
                        <span class="bg-[#1a1b26] border border-[#bb9af7]/30 text-[#bb9af7] px-2 py-1 rounded text-xs">Backend</span>
                        <span class="bg-[#1a1b26] border border-[#e0af68]/30 text-[#e0af68] px-2 py-1 rounded text-xs">AI Automation</span>
                    </div>
                </div>
                <div>
                    <div class="text-[#565f89] text-xs mb-1">LOCATION</div>
                    <div class="text-[#c0caf5] flex items-center gap-2">
                        <span class="text-[#f7768e]">📍</span> Sri Lanka (Open to Remote)
                    </div>
                </div>
            </div>
        </div>
    </div>
</section> 