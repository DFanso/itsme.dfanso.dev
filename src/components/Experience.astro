    {
        type: "CTO",
        typeColor: "text-[#f7768e]", // Red/Pink
        file: "klexd.md",
        title: "Co-Founder & CTO @ KlexD",
        period: "October 2024 - Present",
        responsibilities: [
            "Architecting intelligent systems and smart assistants using Python, OpenAI, and LangChain",
