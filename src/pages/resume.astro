---
import { profile, companies, education, certifications, skillGroups } from '../data/portfolio';

// Flatten all roles for a simple linear view in the CV
const allExperience = companies.flatMap(c =>
    c.roles.map(r => ({ company: c.company, ...r }))
);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} — Resume</title>
    <meta name="description" content={`Resume of ${profile.name} — ${profile.title}`} />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --blue:    #2563eb;
            --dark:    #0f172a;
            --mid:     #334155;
            --muted:   #64748b;
            --light:   #f1f5f9;
            --border:  #e2e8f0;
            --accent:  #0ea5e9;
            --page-w:  210mm;
            --page-h:  297mm;
        }

        body {
            font-family: 'Inter', sans-serif;
            font-size: 9.5pt;
            line-height: 1.5;
            color: var(--dark);
            background: #fff;
        }

        /* ─── Page Layout ──────────────────────────────── */
        .page {
            width: var(--page-w);
            min-height: var(--page-h);
            margin: 0 auto;
            background: #fff;
            display: grid;
            grid-template-columns: 62mm 1fr;
            grid-template-rows: auto 1fr;
        }

        /* ─── Header (full-width) ──────────────────────── */
        .header {
            grid-column: 1 / -1;
            background: var(--dark);
            color: #fff;
            padding: 14mm 12mm 10mm;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 8mm;
        }

        .header-name {
            font-size: 22pt;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #fff;
            line-height: 1.1;
        }

        .header-title {
            font-size: 9.5pt;
            color: #94a3b8;
            margin-top: 2mm;
            font-weight: 400;
        }

        .header-contact {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 2.5mm;
            font-size: 8pt;
            color: #cbd5e1;
            white-space: nowrap;
        }

        .header-contact a {
            color: #93c5fd;
            text-decoration: none;
        }

        .header-contact span { display: flex; align-items: center; gap: 1.5mm; }

        /* ─── Sidebar ──────────────────────────────────── */
        .sidebar {
            background: var(--light);
            padding: 8mm 7mm;
            border-right: 1px solid var(--border);
        }

        /* ─── Main ─────────────────────────────────────── */
        .main {
            padding: 8mm 10mm 8mm 8mm;
        }

        /* ─── Section ──────────────────────────────────── */
        .section { margin-bottom: 6mm; }

        .section-title {
            font-size: 7pt;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--blue);
            border-bottom: 1.5px solid var(--blue);
            padding-bottom: 1.5mm;
            margin-bottom: 4mm;
        }

        /* ─── Experience ───────────────────────────────── */
        .exp-item { margin-bottom: 5mm; }
        .exp-item:last-child { margin-bottom: 0; }

        .exp-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 4mm;
        }

        .exp-title {
            font-size: 9.5pt;
            font-weight: 600;
            color: var(--dark);
        }

        .exp-period {
            font-size: 7.5pt;
            color: var(--muted);
            white-space: nowrap;
            font-family: 'JetBrains Mono', monospace;
        }

        .exp-company {
            font-size: 8.5pt;
            color: var(--blue);
            font-weight: 500;
            margin-bottom: 1.5mm;
        }

        .exp-bullets {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .exp-bullets li {
            font-size: 8.5pt;
            color: var(--mid);
            padding-left: 3.5mm;
            position: relative;
            line-height: 1.5;
            margin-bottom: 0.8mm;
        }

        .exp-bullets li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: var(--accent);
            font-size: 7pt;
            top: 1px;
        }

        .exp-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5mm;
            margin-top: 2mm;
        }

        .tech-tag {
            font-size: 6.5pt;
            background: #e0f2fe;
            color: #0369a1;
            border: 0.5px solid #bae6fd;
            border-radius: 2px;
            padding: 0.5mm 2mm;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500;
        }

        /* ─── Education ────────────────────────────────── */
        .edu-item { margin-bottom: 4mm; }
        .edu-degree { font-size: 9pt; font-weight: 600; color: var(--dark); }
        .edu-institution { font-size: 8.5pt; color: var(--blue); font-weight: 500; }
        .edu-meta { font-size: 7.5pt; color: var(--muted); margin-top: 0.5mm; }
        .edu-grade {
            display: inline-block;
            font-size: 7pt;
            background: #fef3c7;
            color: #92400e;
            border: 0.5px solid #fde68a;
            border-radius: 2px;
            padding: 0.5mm 2mm;
            font-weight: 600;
            margin-top: 1mm;
        }

        /* ─── Certifications ───────────────────────────── */
        .cert-item { margin-bottom: 3.5mm; }
        .cert-name { font-size: 8.5pt; font-weight: 600; color: var(--dark); }
        .cert-issuer { font-size: 8pt; color: var(--blue); font-weight: 500; }
        .cert-meta { font-size: 7pt; color: var(--muted); }

        /* ─── Skills ───────────────────────────────────── */
        .skill-group { margin-bottom: 3.5mm; }
        .skill-group-name {
            font-size: 7.5pt;
            font-weight: 600;
            color: var(--mid);
            margin-bottom: 1.5mm;
        }
        .skill-tags { display: flex; flex-wrap: wrap; gap: 1.5mm; }
        .skill-tag {
            font-size: 7pt;
            background: #fff;
            border: 0.5px solid var(--border);
            border-radius: 2px;
            padding: 0.5mm 2mm;
            color: var(--mid);
        }

        /* ─── Summary ──────────────────────────────────── */
        .summary-text {
            font-size: 8.5pt;
            color: var(--mid);
            line-height: 1.6;
        }

        /* ─── Links ────────────────────────────────────── */
        .contact-link {
            display: flex;
            flex-direction: column;
            gap: 2mm;
            font-size: 7.5pt;
        }

        .contact-link a {
            color: var(--blue);
            text-decoration: none;
        }

        /* ─── Print ────────────────────────────────────── */
        @media print {
            @page {
                size: A4;
                margin: 0;
            }
            body { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
            .page { width: 210mm; min-height: 297mm; }
        }
    </style>
</head>
<body>
<div class="page">

    <!-- ─── Header ─────────────────────────────────────────── -->
    <header class="header">
        <div>
            <div class="header-name">{profile.name}</div>
            <div class="header-title">{profile.title}</div>
        </div>
        <div class="header-contact">
            <span>📍 {profile.location}</span>
            <span>✉ <a href={`mailto:${profile.email}`}>{profile.email}</a></span>
            <span>🔗 <a href={profile.linkedin}>{profile.linkedinHandle}</a></span>
            <span>🌐 <a href={profile.portfolio}>{profile.portfolioHandle}</a></span>
            <span>💻 <a href={profile.github}>{profile.githubHandle}</a></span>
        </div>
    </header>

    <!-- ─── Sidebar ─────────────────────────────────────────── -->
    <aside class="sidebar">

        <!-- Summary -->
        <div class="section">
            <div class="section-title">About</div>
            <p class="summary-text">{profile.summary}</p>
        </div>

        <!-- Skills -->
        <div class="section">
            <div class="section-title">Technical Skills</div>
            {skillGroups.map(g => (
                <div class="skill-group">
                    <div class="skill-group-name">{g.name}</div>
                    <div class="skill-tags">
                        {g.skills.map(s => <span class="skill-tag">{s}</span>)}
                    </div>
                </div>
            ))}
        </div>

        <!-- Certifications -->
        <div class="section">
            <div class="section-title">Certifications</div>
            {certifications.map(cert => (
                <div class="cert-item">
                    <div class="cert-name">{cert.name}</div>
                    <div class="cert-issuer">{cert.issuer}</div>
                    <div class="cert-meta">{cert.date}{cert.expiry ? ` · ${cert.expiry}` : ''}</div>
                    {cert.id && <div class="cert-meta">{cert.id}</div>}
                </div>
            ))}
        </div>

        <!-- Education -->
        <div class="section">
            <div class="section-title">Education</div>
            {education.map(edu => (
                <div class="edu-item">
                    <div class="edu-degree">{edu.degree}</div>
                    <div class="edu-institution">{edu.institution}</div>
                    <div class="edu-meta">{edu.period} · {edu.location}</div>
                    {edu.grade && <div class="edu-grade">🏆 {edu.grade}</div>}
                </div>
            ))}
        </div>

    </aside>

    <!-- ─── Main ─────────────────────────────────────────────── -->
    <main class="main">
        <div class="section">
            <div class="section-title">Experience</div>
            {allExperience.map(exp => (
                <div class="exp-item">
                    <div class="exp-header">
                        <div class="exp-title">{exp.title}</div>
                        <div class="exp-period">{exp.period}</div>
                    </div>
                    <div class="exp-company">{exp.company}</div>
                    <ul class="exp-bullets">
                        {exp.responsibilities.map(r => <li>{r}</li>)}
                    </ul>
                    <div class="exp-tech">
                        {exp.tech.map(t => <span class="tech-tag">{t.name}</span>)}
                    </div>
                </div>
            ))}
        </div>
    </main>

</div>
</body>
</html>
